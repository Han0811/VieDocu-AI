# ── API / BACKEND CONFIGURATION ──────────────────────────────────────
# Port for uvicorn to bind to (default: 8000)
PORT=8000
HOST=0.0.0.0

# Maximum uploaded file size (default: 100MB)
MAX_UPLOAD_MB=100

# PDF rendering options
MAX_PDF_PAGES=50
PDF_DPI=220

# Database URL for job metadata storage
# SQLite path inside container or external Postgres URL
# SQLite default: sqlite:///backend_runs/jobs.sqlite3
# PostgreSQL example: postgresql://user:pass@localhost:5432/ocr_db
DATABASE_URL=sqlite:///backend_runs/jobs.sqlite3

# Redis URL for production task queue (default: redis://localhost:6379/0)
REDIS_URL=redis://localhost:6379/0

# Optional API Key security
ENABLE_API_KEY=false
API_KEY=your_secret_api_key_here

# CORS allowed origins (comma-separated list)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000


# ── FRONTEND CONFIGURATION ───────────────────────────────────────────
# Base API URL used by Next.js client
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
